datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Usuario {
  idUsuario    Int           @id @default(autoincrement())
  nomeUsuario  String
  email        String        @unique
  senha        String
  
  // Relações 1:1 opcionais (torna-se)
  gerenteGeral GerenteGeral?
  liderEquipe  LiderEquipe?
  vendedor     Vendedor?
}

model GerenteGeral {
  idGerente   Int      @id @default(autoincrement())
  idUsuario   Int      @unique
  nivelAcesso String
  
  usuario     Usuario  @relation(fields: [idUsuario], references: [idUsuario])
  equipes     Equipe[] // Gerencia várias equipes
}

model Equipe {
  idEquipe     Int           @id @default(autoincrement())
  idGerente    Int
  nomeEquipe   String
  
  gerente      GerenteGeral  @relation(fields: [idGerente], references: [idGerente])
  lider        LiderEquipe?  // 1:1 com Equipe
  vendedores   Vendedor[]
}

model LiderEquipe {
  idLiderEquipe Int        @id @default(autoincrement())
  idUsuario     Int        @unique
  idEquipe      Int        @unique
  
  usuario       Usuario    @relation(fields: [idUsuario], references: [idUsuario])
  equipe        Equipe     @relation(fields: [idEquipe], references: [idEquipe])
  vendedores    Vendedor[] // Supervisão direta dos vendedores
}

model Vendedor {
  idVendedor    Int          @id @default(autoincrement())
  idUsuario     Int          @unique
  idEquipe      Int
  idLiderEquipe Int
  
  usuario       Usuario      @relation(fields: [idUsuario], references: [idUsuario])
  equipe        Equipe       @relation(fields: [idEquipe], references: [idEquipe])
  lider         LiderEquipe  @relation(fields: [idLiderEquipe], references: [idLiderEquipe])
  
  leads         Lead[]
  vendas        Venda[]
}

model Cliente {
  idCliente       Int      @id @default(autoincrement())
  nomeCliente     String
  emailCliente    String   @unique
  cpfCliente      String   @unique
  telefoneCelular String
  descricao       String?
  
  leads           Lead[]
}

model OrigemLead {
  idOrigem      Int    @id @default(autoincrement())
  nomeOrigem    String
  leads         Lead[]
}

model Carro {
  idCarro       Int     @id @default(autoincrement())
  vinChassi     String  @unique @map("vin_chassi")
  placa         String  @unique
  marca         String
  modelo        String
  anoFabricacao Int
  valorEstoque  Float
  cor           String
  
  leads         Lead[]
  vendas        Venda[]
}

model Lead {
  idLead      Int         @id @default(autoincrement())
  idCliente   Int
  idVendedor  Int
  idOrigem    Int
  idCarro     Int
  statusLead  String
  nomeLead    String

  cliente     Cliente     @relation(fields: [idCliente], references: [idCliente])
  vendedor    Vendedor    @relation(fields: [idVendedor], references: [idVendedor])
  origem      OrigemLead  @relation(fields: [idOrigem], references: [idOrigem])
  carro       Carro       @relation(fields: [idCarro], references: [idCarro])
  venda       Venda?
}

model Venda {
  idVenda        Int      @id @default(autoincrement())
  idLead         Int      @unique
  idVendedor     Int
  idCarro        Int
  valorVenda     Float
  dataVenda      DateTime @default(now())
  formaPagamento String

  lead           Lead     @relation(fields: [idLead], references: [idLead])
  vendedor       Vendedor @relation(fields: [idVendedor], references: [idVendedor])
  carro          Carro    @relation(fields: [idCarro], references: [idCarro])
}